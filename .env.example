# Copy to .env (or wire into your CI secrets) and adjust per environment.

# WebSocket URL of the deployed signaling server (used only for the WebRTC
# relay path, i.e. when peers are on different networks).
NEARDROP_SIGNALING_URL=wss://signal.neardrop.example.com

# Default TCP port used for local P2P transfer and mDNS advertising.
NEARDROP_TRANSFER_PORT=7531
